<?xml version="1.0" encoding="utf-8"?>
<!--
  Layout for PairWithEmailActivity.
  A clean card-style screen where the user enters their email to
  auto-discover the PC on the same WiFi — no QR code needed.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#121212">

    <!-- App Icon / Logo area -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🖥"
        android:textSize="64sp"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:layout_gravity="center" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connect to PC"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Both devices must be on the same WiFi network\nand signed in with the same email."
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- Email input card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#1E1E1E"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <EditText
            android:id="@+id/emailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:hint="Enter your email address"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@null"
            android:textSize="16sp"
            android:imeOptions="actionDone"
            android:singleLine="true" />

    </androidx.cardview.widget.CardView>

    <!-- Connect button -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Connect to PC"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#4F8EF7"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        android:indeterminateTint="#4F8EF7" />

    <!-- Status / error message -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
